{
	"name": "nh-tool",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"main": "electron.js",
	"scripts": {
		"dev": "vite",
		"backend": "node index.js",
		"all": "concurrently \"npm run backend\" \"npm run dev\"",
		"generate-wrangler": "node scripts/generate-wrangler.js",
		"build": "npm run generate-wrangler && vite build",
		"electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
		"electron:build": "npm run build && electron-builder",
		"lint": "eslint .",
		"preview": "npm run build && vite preview",
		"deploy": "npm run build && wrangler deploy --config wrangler.generated.toml"
	},
	"build": {
		"appId": "com.nicehash.toolbox",
		"productName": "NiceHash Toolbox",
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"index.js",
			"electron.js",
			"NiceHashClient.js",
			"algoMapping.js",
			"node_modules/**/*"
		],
		"win": {
			"target": "portable",
			"extraFiles": [
				".env"
			]
		}
	},
	"dependencies": {
		"axios": "^1.16.1",
		"dotenv": "^17.4.2",
		"expo-file-system": "^56.0.7",
		"expo-sharing": "^14.0.8",
		"express": "^5.2.1",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"uuid": "^14.0.0",
		"xlsx": "^0.18.5"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.38.0",
		"@eslint/js": "^10.0.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/uuid": "^10.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"cross-env": "^7.0.3",
		"electron": "^42.3.0",
		"electron-builder": "^26.8.1",
		"eslint": "^10.3.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.6.0",
		"vite": "^8.0.12",
		"wait-on": "^7.2.0",
		"wrangler": "^4.95.0"
	}
}
